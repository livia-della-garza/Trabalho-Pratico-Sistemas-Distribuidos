# Ollama (opcional — requer daemon em execução)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

# Google Gemini (obrigatório para Docker)
GEMINI_API_KEY=sua-chave-aqui
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=models/text-embedding-004

# PostgreSQL
POSTGRES_DSN=postgresql://academic:academic@localhost:5433/academic_assistant

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8004

# Microsserviços (dev local)
ROUTING_URL=http://localhost:8001
FALLBACK_URL=http://localhost:8002
RAG_URL=http://localhost:8003

# Frontend
GATEWAY_WS_URL=ws://localhost:8000/ws

# RAG
RAG_TOP_K=4
