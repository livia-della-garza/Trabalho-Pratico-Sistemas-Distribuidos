# Ollama (LLM e embeddings locais)
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
OLLAMA_CHAT_MODEL=qwen3.5:0.8b

# PostgreSQL — um banco por microsserviço
ROUTING_POSTGRES_DSN=postgresql://academic:academic@localhost:5433/routing
FALLBACK_POSTGRES_DSN=postgresql://academic:academic@localhost:5434/fallback
RAG_POSTGRES_DSN=postgresql://academic:academic@localhost:5435/rag

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8004

# Microsserviços (dev local)
ROUTING_URL=http://localhost:8001
FALLBACK_URL=http://localhost:8002
RAG_URL=http://localhost:8003

# Frontend
GATEWAY_WS_URL=ws://localhost:8000/ws

# RAG
RAG_TOP_K=4
